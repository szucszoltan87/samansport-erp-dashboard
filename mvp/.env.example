# =============================================================================
# SamanSport ERP Dashboard — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Tharanis SOAP API (used by both the Streamlit app and Supabase Edge Functions)
# -----------------------------------------------------------------------------

# Base URL of the Tharanis API v3 endpoint
THARANIS_API_URL=https://login.tharanis.hu/apiv3.php

# API authentication key (Python app reads this as THARANIS_API_KEY)
THARANIS_API_KEY=your_api_key_here

# Customer code — identifies the Tharanis tenant (default: 7354)
THARANIS_UGYFELKOD=7354

# Company code within the tenant (default: ab)
THARANIS_CEGKOD=ab

# -----------------------------------------------------------------------------
# Supabase — Streamlit app (client-side, read-only)
# Leave both empty to fall back to direct SOAP queries (no caching).
# -----------------------------------------------------------------------------

# Your Supabase project URL (e.g. https://<project-ref>.supabase.co)
SUPABASE_URL=

# Supabase anonymous / publishable key (safe to expose in client apps)
SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Supabase — Edge Functions only (server-side, privileged)
# Set these in the Supabase dashboard under Project Settings → Edge Functions,
# or pass them when running `supabase functions serve` locally.
# NEVER commit actual values.
# -----------------------------------------------------------------------------

# Service-role key — full database access, used by Edge Functions for upserts
SUPABASE_SERVICE_ROLE_KEY=

# API key used by the TypeScript SOAP client inside Edge Functions
# (same credential as THARANIS_API_KEY, but read under a different name in Deno)
THARANIS_APIKULCS=your_api_key_here
